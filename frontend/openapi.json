          "batting_team_id": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Batting Team Id"
          },
          "fielding_team_id": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Fielding Team Id"
          },
          "event": {
            "type": "string",
            "enum": [
              "out",
              "walk",
              "single",
              "double",
              "triple",
              "home_run",
              "tiebreaker"
            ],
            "title": "Event"
          },
          "outs_before": {
            "type": "integer",
            "maximum": 3.0,
            "minimum": 0.0,
            "title": "Outs Before"
