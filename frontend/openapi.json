          "outs_after": {
            "type": "integer",
            "maximum": 3.0,
            "minimum": 0.0,
            "title": "Outs After"
          },
          "bases_before": {
            "type": "string",
            "pattern": "^[01]{3}$",
            "title": "Bases Before"
          },
          "bases_after": {
            "type": "string",
            "pattern": "^[01]{3}$",
            "title": "Bases After"
          },
          "runs_scored_on_play": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Runs Scored On Play"
          },
          "home_score_after_play": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Home Score After Play"
          },
          "away_score_after_play": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Away Score After Play"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "batter_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Batter Id"
          },
          "batter_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Batter Name"
          }
