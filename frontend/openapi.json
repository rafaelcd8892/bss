        "properties": {
          "play_index": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Play Index"
          },
          "inning": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Inning"
          },
          "half": {
            "type": "string",
