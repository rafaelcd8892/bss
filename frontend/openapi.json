  "components": {
    "schemas": {
      "ComparePlayersRequest": {
        "properties": {
          "left_player_id": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Left Player Id"
          },
          "right_player_id": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Right Player Id"
          },
          "context": {
            "$ref": "#/components/schemas/DeterministicContext"
          }
        },
        "type": "object",
        "required": [
          "left_player_id",
          "right_player_id",
          "context"
        ],
        "title": "ComparePlayersRequest"
      },
      "ComparePlayersResponse": {
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          },
          "result": {
            "$ref": "#/components/schemas/ComparePlayersResult"
          }
        },
        "type": "object",
        "required": [
          "meta",
          "result"
        ],
        "title": "ComparePlayersResponse"
      },
      "ComparePlayersResult": {
        "properties": {
          "left_player_id": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Left Player Id"
          },
          "right_player_id": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Right Player Id"
          },
          "metrics": {
            "additionalProperties": {
              "$ref": "#/components/schemas/MetricComparison"
            },
            "type": "object",
            "title": "Metrics"
          },
          "summary": {
            "type": "string",
            "title": "Summary"
          }
        },
        "type": "object",
        "required": [
          "left_player_id",
          "right_player_id",
          "metrics",
          "summary"
        ],
        "title": "ComparePlayersResult"
      },
      "DeterministicContext": {
        "properties": {
          "seed": {
            "type": "integer",
            "maximum": 4294967295.0,
            "minimum": 0.0,
            "title": "Seed"
          },
          "model_version": {
            "type": "string",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._-]+$",
            "title": "Model Version"
          },
          "data_snapshot_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:-]+$",
            "title": "Data Snapshot Id"
          }
        },
        "type": "object",
        "required": [
          "seed",
          "model_version",
          "data_snapshot_id"
        ],
        "title": "DeterministicContext",
        "description": "Deterministic execution contract for all stochastic endpoints."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MetricComparison": {
        "properties": {
