        "required": [
          "play_index",
          "inning",
          "half",
          "batting_team_id",
          "fielding_team_id",
          "event",
          "outs_before",
          "outs_after",
          "bases_before",
          "bases_after",
          "runs_scored_on_play",
          "home_score_after_play",
          "away_score_after_play",
