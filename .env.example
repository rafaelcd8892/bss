BASEBALL_APP_NAME=baseball-sim
BASEBALL_APP_ENV=dev
BASEBALL_API_PREFIX=/api/v1
BASEBALL_DB_DSN=postgresql://postgres:postgres@localhost:5432/baseball
BASEBALL_MIGRATIONS_DIR=migrations
BASEBALL_RAW_DATA_DIR=data/raw
BASEBALL_MLB_STATS_API_BASE_URL=https://statsapi.mlb.com/api/v1
BASEBALL_MLB_STATS_TIMEOUT_SECONDS=15
BASEBALL_MLB_STATS_MAX_ATTEMPTS=3
BASEBALL_MLB_STATS_BACKOFF_SECONDS=0.25
BASEBALL_MLB_STATS_SPORT_ID=1
BASEBALL_SIMULATOR_RULESET_PATH=rulesets/mlb_2026_regular.json
BASEBALL_DEFAULT_SEED=42
BASEBALL_DEFAULT_MODEL_VERSION=baseline-v1
BASEBALL_DEFAULT_DATA_SNAPSHOT_ID=snapshot-bootstrap-0001
BASEBALL_RESPONSE_ROUNDING_DECIMALS=4
